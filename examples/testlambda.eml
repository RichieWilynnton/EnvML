type ty =
  TNat as unit
| TBool as unit
| TArrow as {arg : ty, ret : ty};

type exp =
  Var as {str : string}
| Lam as {name : string, argT : ty, body : exp}
| App as {funcE : exp, argE : exp}
| Nat as {n : int};

type maybe = forall t.
    Just as t
| Error as string;

type tyCtx =
    CtxNil as unit
| CtxCons as {name : string, entryT : ty, rest : tyCtx};

let subst : string -> exp -> exp -> exp =
    fix go. fun (name : string) (value : exp) (e : exp) -> (
        case e of
        | <Var = v> =>
            if (v.str == name) then
                value
            else
                Var(v) as exp
        
        | <Lam = l> =>
            if (l.name == name) then
                Lam({name = l.name, argT = l.argT, body = l.body}) as exp
            else
                Lam({name = l.name, argT = l.argT, body = go(name)(value)(l.body)}) as exp
        | <App = a> =>
            App({
                funcE = go(name)(value)(a.funcE),
                argE = go(name)(value)(a.argE)
            }) as exp
        | <Nat = n> => Nat(n) as exp
    );

let eval : exp -> maybe<exp> =
    fix go. fun (e : exp) -> (
        case e of
        | <Var = v> => Error("Runtime error: unbound variable") as maybe<exp>
        | <Lam = l> => Just(e) as maybe<exp>
        | <Nat = n> => Just(e) as maybe<exp>
        | <App = a> => 
            case go(a.funcE) of
            | <Error = errF> => Error(errF) as maybe<exp>
            | <Just = funcVal> =>
                case go(a.argE) of
                | <Error = errA> => Error(errA) as maybe<exp>
                | <Just = argVal> => 
                    case funcVal of
                    | <Lam = f> => go(subst (f.name) (argVal) (f.body))
                    | _ => Error("Runtime error: head of application is not a lambda") as maybe<exp>
                     
    );

let lookupTy : string -> tyCtx -> maybe<ty> =
    fix go. fun (name : string) (ctx : tyCtx) -> (
        case ctx of
        | <CtxNil = n> => Error("Type error: variable not found in context") as maybe<ty>
        | <CtxCons = c> =>
            if (c.name == name) then
                Just(c.entryT) as maybe<ty>
            else
                go(name)(c.rest)
    );

let extendCtx : string -> ty -> tyCtx -> tyCtx =
    fun (name : string) (entryT : ty) (rest : tyCtx) ->
        CtxCons({name = name, entryT = entryT, rest = rest}) as tyCtx;

let typeCheck : tyCtx -> exp -> maybe<ty> =
    fix go. fun (ctx : tyCtx) (e : exp) -> (
        case e of
        | <Var = v> => lookupTy(v.str)(ctx)
        | <Nat = n> => Just(TNat(()) as ty) as maybe<ty>
        | <Lam = l> => (
            case go(extendCtx(l.name)(l.argT)(ctx))(l.body) of
            | <Just = bodyT> =>
                Just(TArrow({arg = l.argT, ret = bodyT}) as ty) as maybe<ty>
            | <Error = err> => Error(err) as maybe<ty>
        )
        | <App = a> =>
            case go(ctx)(a.funcE) of
            | <Error = errF> => Error(errF) as maybe<ty>
            | <Just = funcT> =>
                case go(ctx)(a.argE) of
                | <Error = errA> => Error(errA) as maybe<ty>
                | <Just = argT> =>
                    case funcT of
                    | <TArrow = arr> =>
                        if arr.arg == argT then
                            Just(arr.ret) as maybe<ty>
                        else
                            Error("Type error: argument type mismatch") as maybe<ty>
                    | _ => Error("Type error: attempted to apply a non-function") as maybe<ty>
    );

