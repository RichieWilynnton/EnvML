------ ========== eval and check test ==========
let emptyTyCtx = CtxNil(()) as tyCtx;

let checkExample = box [
  body = App({funcE = Var({str = "x"}) as exp, argE = Var({str = "y"}) as exp}) as exp,
  funY = Lam({name = "y", argT = TNat(()) as ty, body = body}) as exp, 
  funX = Lam({name = "x", argT = TArrow ({arg = TNat(()) as ty, ret = TNat(()) as ty}) as ty, body = funY}) as exp,
  id = Lam({name = "x", argT = TNat(()) as ty, body = Var({str = "x"}) as exp}) as exp, 
  two = Nat({n = 2}) as exp,
  
  app1 = App ({funcE = funX, argE = id}) as exp,
  app2 = App ({funcE = app1, argE = two}) as exp,

  typeCheck = typeCheck,
  eval = eval,
  emptyTyCtx = emptyTyCtx
] in 
-- ***** human readable version ******
-- app2 == (fun (x : nat -> nat) -> fun (y : nat) -> x(y)) (fun (x : nat) -> x) (2)
struct

    let typeCheckRes = typeCheck (emptyTyCtx) (app2);
    let evalRes = eval (app2);
end
;
