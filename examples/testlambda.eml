  body = App({funcE = Var({str = "x"}) as exp, argE = Var({str = "y"}) as exp}) as exp,
  lam = Lam({name = "y", argT = TNat(()) as ty, body = body}) as exp, 
  target = App({funcE = lam, argE = Var({str = "y"}) as exp}) as exp, 
