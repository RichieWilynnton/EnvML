type ty =
  TNat as unit
| TBool as unit
| TArrow as {arg : ty, ret : ty};

type exp =
  Var as {str : string}
| Lam as {name : string, argT : ty, body : exp}
| App as {funcE : exp, argE : exp}
| Nat as {n : int};

type maybeExp =
    JustExp as exp
| ErrorExp as string;

type maybeTyp =
    JustTyp as ty
| ErrorTyp as string;

type tyCtx =
    CtxNil as unit
| CtxCons as {name : string, entryT : ty, rest : tyCtx};

let subst : string -> exp -> exp -> exp =
    fix go. fun (name : string) (value : exp) (e : exp) -> (
        case e of
        | <Var = v> =>
            if (v.str == name) then
                value
            else
                Var(v) as exp
        
        | <Lam = l> =>
            if (l.name == name) then
                Lam({name = l.name, argT = l.argT, body = l.body}) as exp
            else
                Lam({name = l.name, argT = l.argT, body = go(name)(value)(l.body)}) as exp
        | <App = a> =>
            App({
                funcE = go(name)(value)(a.funcE),
                argE = go(name)(value)(a.argE)
            }) as exp
        | <Nat = n> => Nat(n) as exp
    );

let eval : exp -> maybeExp =
    fix go. fun (e : exp) -> (
        case e of
        | <Var = v> => ErrorExp("Runtime error: unbound variable") as maybeExp
        | <Lam = l> => JustExp(e) as maybeExp
        | <Nat = n> => JustExp(e) as maybeExp
        | <App = a> => 
            case go(a.funcE) of
            | <ErrorExp = errF> => ErrorExp(errF) as maybeExp
            | <JustExp = funcVal> =>
                case go(a.argE) of
                | <ErrorExp = errA> => ErrorExp(errA) as maybeExp
                | <JustExp = argVal> => 
                    case funcVal of
                    | <Lam = f> => go(subst (f.name) (argVal) (f.body))
                    | _ => ErrorExp("Runtime error: head of application is not a lambda") as maybeExp
                     
    );

let lookupTy : string -> tyCtx -> maybeTyp =
    fix go. fun (name : string) (ctx : tyCtx) -> (
        case ctx of
        | <CtxNil = n> => ErrorTyp("Type error: variable not found in context") as maybeTyp
        | <CtxCons = c> =>
            if (c.name == name) then
                JustTyp(c.entryT) as maybeTyp
            else
                go(name)(c.rest)
    );

let extendCtx : string -> ty -> tyCtx -> tyCtx =
    fun (name : string) (entryT : ty) (rest : tyCtx) ->
        CtxCons({name = name, entryT = entryT, rest = rest}) as tyCtx;

let typeCheck : tyCtx -> exp -> maybeTyp =
    fix go. fun (ctx : tyCtx) (e : exp) -> (
        case e of
        | <Var = v> => lookupTy(v.str)(ctx)
        | <Nat = n> => JustTyp(TNat(()) as ty) as maybeTyp
        | <Lam = l> => (
            case go(extendCtx(l.name)(l.argT)(ctx))(l.body) of
            | <JustTyp = bodyT> =>
                JustTyp(TArrow({arg = l.argT, ret = bodyT}) as ty) as maybeTyp
            | <ErrorTyp = err> => ErrorTyp(err) as maybeTyp
        )
        | <App = a> =>
            case go(ctx)(a.funcE) of
            | <ErrorTyp = errF> => ErrorTyp(errF) as maybeTyp
            | <JustTyp = funcT> =>
                case go(ctx)(a.argE) of
                | <ErrorTyp = errA> => ErrorTyp(errA) as maybeTyp
                | <JustTyp = argT> =>
                    case funcT of
                    | <TArrow = arr> =>
                        if arr.arg == argT then
                            JustTyp(arr.ret) as maybeTyp
                        else
                            ErrorTyp("Type error: argument type mismatch") as maybeTyp
                    | _ => ErrorTyp("Type error: attempted to apply a non-function") as maybeTyp
    );

