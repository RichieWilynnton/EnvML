-- sepcomptest_8: Test importing types from .emli files
--
--   math  (type Num = int, add, square)
--     │
--   main  (uses math.Num via .emli import)
--
:sep-obj examples/sepcomptest_8/math.eml
:sep-link examples/sepcomptest_8/math.emlo
:sep-obj examples/sepcomptest_8/main.eml
:sep-link examples/sepcomptest_8/main.emlo examples/sepcomptest_8/math.emle
