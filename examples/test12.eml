module type ACCESS_POLICY = 
  forall t. sig 
    val reshape : list t -> list t; 
  end;

module queryProcessor : 
  ACCESS_POLICY
  ->m sig 
        type a = int; 
        val query : list a -> list a; 
      end
  = functor (policy) ->
      struct
        type a = int;
        let query : list a -> list a = ((policy @a) :: sig val reshape : list int -> list int; end).reshape;
      end;
